{
  "name": "kn-dev",
  "image": "ubuntu:22.04-custom",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "runArgs": ["--name=kn-dev"],

  "mounts": [
    "source=${localEnv:HOME}/Desktop,target=/desktop,type=bind",
    "source=${localEnv:HOME}/Desktop/Sync/Software/Linux/offline-cache/apt-lists,target=/var/lib/apt/lists,type=bind",
    "source=${localEnv:HOME}/Desktop/Sync/Software/Linux/offline-cache/apt-archives,target=/var/cache/apt/archives,type=bind",
    "source=${localEnv:HOME}/Desktop/Sync/Software/Linux/offline-cache/pip-wheels,target=/wheels,type=bind"
  ]
}
